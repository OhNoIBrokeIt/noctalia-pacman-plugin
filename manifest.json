{
  "id": "update-checker",
  "name": "Update Checker",
  "version": "1.1.0",
  "minNoctaliaVersion": "3.6.0",
  "author": "ohnoibrokeit",
  "official": false,
  "repository": "https://github.com/OhNoIBrokeIt/noctalia-update-checker",
  "license": "MIT",
  "description": "Pac-Man themed system update checker for pacman-based distros.",
  "tags": [
    "Bar",
    "System"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "checkIntervalMs": 7200000,
      "initialAnimationMs": 120000,
      "idleChompMs": 30000,
      "useThemedIdleColor": true,
      "showIdlePellet": true
    }
  }
}
